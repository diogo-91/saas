          "conditions": [
            {
              "id": "cond-moved",
              "leftValue": "={{ $json.movedToNotScheduled }}",
              "rightValue": 0,
              "operator": {
                "type": "number",
                "operation": "gt"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "a1b2c3d4-0003-4000-8000-000000000003",
      "name": "Houve movimentações?",
