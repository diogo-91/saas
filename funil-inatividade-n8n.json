              "id": "assign-1",
              "name": "status",
              "value": "✅ MOVIMENTADO",
              "type": "string"
            },
            {
              "id": "assign-2",
              "name": "quantidade",
              "value": "={{ $('Verificar Inatividade').item.json.movedToNotScheduled }}",
              "type": "number"
